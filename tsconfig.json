{
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "sourceMap": true,
    "lib": ["es2019", "dom"],
    "strictNullChecks": true,
    "importHelpers": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "pretty": true,
    "target": "es2019",
    "jsx": "react-jsx",
    "types": ["@electron-forge/plugin-vite/forge-vite-env"],
    "skipLibCheck": true
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules"]
}
